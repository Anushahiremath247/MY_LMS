generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ResourceType {
  video
  search
  playlist
}

enum Difficulty {
  beginner
  intermediate
  advanced
}

enum UserRole {
  student
  admin
}

enum CertificateStatus {
  earned
  in_progress
}

enum CourseAccessType {
  free
  paid
  subscription
}

enum PaymentStatus {
  pending
  succeeded
  failed
}

enum PaymentMethod {
  upi
  card
  bank_transfer
}

enum PaymentType {
  course_purchase
  subscription
}

enum OrderStatus {
  pending
  paid
  failed
  canceled
}

enum SubscriptionBillingCycle {
  monthly
  yearly
}

enum UserSubscriptionStatus {
  active
  expired
  canceled
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  passwordHash  String
  name          String
  avatar        String?
  role          UserRole        @default(student)
  lastLoginAt   DateTime?
  deactivatedAt DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  enrollments   Enrollment[]
  progress      VideoProgress[]
  refreshTokens RefreshToken[]
  profile       Profile?
  privacy       PrivacySetting?
  notifications NotificationSetting?
  certificates  Certificate[]
  activityLogs  ActivityLog[]
  resetTokens   PasswordResetToken[]
  orders        Order[]
  payments      Payment[]
  subscriptions UserSubscription[]
  purchases     PurchasedCourse[]
  watchHistory  WatchHistory[]
}

model Subject {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  description    String
  shortDescription String
  thumbnail      String
  instructor     String
  duration       String
  rating         Float         @default(4.8)
  category       String
  level          String        @default("Beginner")
  accessType     CourseAccessType @default(free)
  price          Int           @default(0)
  listPrice      Int           @default(0)
  previewLessonsCount Int      @default(0)
  subscriptionPlanCode String?
  lessonsCount   Int
  published      Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  sections       Section[]
  enrollments    Enrollment[]
  certificates   Certificate[]
  orders         Order[]
  purchases      PurchasedCourse[]
  watchHistory   WatchHistory[]

  @@index([published, createdAt])
  @@index([category])
  @@index([accessType])
}

model Section {
  id         String   @id @default(cuid())
  subjectId  String
  title      String
  orderIndex Int
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  videos     Video[]

  @@index([subjectId, orderIndex])
}

model Video {
  id              String          @id @default(cuid())
  sectionId       String
  title           String
  description     String
  youtubeId       String
  youtubeUrl      String
  embedUrl        String
  thumbnailUrl    String
  durationSeconds Int
  orderIndex      Int
  isPreview       Boolean         @default(false)
  section         Section         @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress        VideoProgress[]
  watchHistory    WatchHistory[]

  @@index([sectionId, orderIndex])
  @@index([youtubeId])
}

model Enrollment {
  id          String   @id @default(cuid())
  userId      String
  subjectId   String
  enrolledAt  DateTime @default(now())
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
  @@index([subjectId])
}

model VideoProgress {
  id                  String    @id @default(cuid())
  userId              String
  videoId             String
  lastPositionSeconds Int       @default(0)
  isCompleted         Boolean   @default(false)
  completedAt         DateTime?
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  video               Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId, isCompleted])
  @@index([videoId])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model SubscriptionPlan {
  id                String                 @id @default(cuid())
  code              String                 @unique
  name              String
  tagline           String
  description       String
  priceMonthly      Int
  priceYearly       Int
  features          String
  isRecommended     Boolean                @default(false)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  orders            Order[]
  userSubscriptions UserSubscription[]

  @@index([code])
}

model Order {
  id                 String        @id @default(cuid())
  userId             String
  subjectId          String?
  subscriptionPlanId String?
  status             OrderStatus   @default(pending)
  amount             Int
  currency           String        @default("INR")
  reference          String        @unique
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject            Subject?      @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  subscriptionPlan   SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id], onDelete: SetNull)
  payments           Payment[]
  purchases          PurchasedCourse[]

  @@index([userId, createdAt])
  @@index([subjectId])
  @@index([subscriptionPlanId])
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  orderId     String
  type        PaymentType
  amount      Int
  currency    String        @default("INR")
  status      PaymentStatus @default(pending)
  method      PaymentMethod
  reference   String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  purchases   PurchasedCourse[]
  subscriptions UserSubscription[]

  @@index([userId, createdAt])
  @@index([orderId])
  @@index([status])
}

model UserSubscription {
  id           String                 @id @default(cuid())
  userId       String
  planId       String
  paymentId    String?
  billingCycle SubscriptionBillingCycle
  status       UserSubscriptionStatus @default(active)
  startedAt    DateTime               @default(now())
  expiresAt    DateTime
  canceledAt   DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  payment      Payment?               @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([userId, status, expiresAt])
  @@index([planId])
}

model PurchasedCourse {
  id         String   @id @default(cuid())
  userId     String
  subjectId  String
  orderId    String
  paymentId  String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment    Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
  @@index([userId, createdAt])
  @@index([subjectId])
}

model WatchHistory {
  id              String    @id @default(cuid())
  userId          String
  subjectId       String
  videoId         String
  progressSeconds Int       @default(0)
  completed       Boolean   @default(false)
  watchedAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject         Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  video           Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([userId, watchedAt])
  @@index([subjectId])
  @@index([videoId])
}

model LearningResource {
  id         String       @id @default(cuid())
  title      String
  category   String
  youtubeUrl String
  type       ResourceType
  difficulty Difficulty
  createdAt  DateTime     @default(now())

  @@index([category])
  @@index([difficulty])
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  username  String   @unique
  phone     String?
  bio       String?
  skills    String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationSetting {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  emailNotifications        Boolean  @default(true)
  courseUpdateNotifications Boolean  @default(true)
  newContentAlerts          Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrivacySetting {
  id                String   @id @default(cuid())
  userId            String   @unique
  profileVisibility Boolean  @default(true)
  showEmail         Boolean  @default(true)
  showPhone         Boolean  @default(false)
  showBio           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Certificate {
  id        String            @id @default(cuid())
  userId    String
  subjectId String?
  title     String
  status    CertificateStatus @default(in_progress)
  issuedAt  DateTime?
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   Subject?          @relation(fields: [subjectId], references: [id], onDelete: SetNull)
}

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  description String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
